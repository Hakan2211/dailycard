{
  "name": "dailycard",
  "version": "1.0.0",
  "description": "Daily Card Draw - Motivational card drawing app",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "images:optimize": "node scripts/optimize-images.mjs",
    "images:optimize:de": "node scripts/optimize-images.mjs --lang de",
    "images:parse": "node scripts/parse-markdown.mjs",
    "images:catalog": "node --env-file=.env.local scripts/build-catalog.mjs",
    "images:catalog:de": "node --env-file=.env.local scripts/build-catalog.mjs --lang de",
    "images:upload": "node --env-file=.env.local scripts/upload-r2.mjs",
    "images:cors": "node --env-file=.env.local scripts/set-r2-cors.mjs",
    "images:all": "node scripts/optimize-images.mjs && node scripts/parse-markdown.mjs && node --env-file=.env.local scripts/build-catalog.mjs && node --env-file=.env.local scripts/upload-r2.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@auth/core": "^0.37.0",
    "@convex-dev/auth": "^0.0.91",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router": "^1.166.3",
    "@tanstack/react-start": "^1.166.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.35.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@types/three": "^0.180.0",
    "@vitejs/plugin-react": "^5.1.4",
    "sharp": "^0.35.2"
  }
}
