# Get this from your Convex dashboard after running `npx convex dev`
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# --- Cloudflare R2 (card-image pipeline; used only by scripts/, never shipped to client) ---
# Account id is in your R2 dashboard URL. Create an R2 API token (Object Read & Write)
# for the key/secret. Bucket is whatever you named it. Public base URL = the bucket's
# "Public Development URL" (https://pub-<hash>.r2.dev), no trailing slash.
R2_ACCOUNT_ID=31de9d120e33c5dfb42c238fb4c43356
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=dailycard-images
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev
